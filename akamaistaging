#!/usr/bin/env python3
import os
import platform
import subprocess
import sys

def is_running_inside_flatpak():
    return "FLATPAK_SANDBOX_DIR" in os.environ

def escalate_privileges_linux():
    print("Requesting root privileges on Linux...")
    if is_running_inside_flatpak():
        # Use flatpak-spawn for privilege escalation inside Flatpak
        print("Running inside Flatpak, using flatpak-spawn...")
        subprocess.run(["flatpak-spawn", "--host", sys.executable] + sys.argv)
    else:
        # Use sudo for privilege escalation outside Flatpak
        print("Not running inside Flatpak, using sudo...")
        sudo_command = ["sudo", sys.executable] + sys.argv
        os.execvp("sudo", sudo_command)

def escalate_privileges_mac():
    print("Requesting root privileges on macOS...")
    script = f'do shell script "{sys.executable} {os.path.abspath(sys.argv[0])}" with administrator privileges'
    subprocess.call(["osascript", "-e", script])
    sys.exit(0)

if __name__ == "__main__":
    print("Starting application...")
    if not os.geteuid() == 0:
        if platform.system() == "Linux":
            escalate_privileges_linux()
        elif platform.system() == "Darwin":
            escalate_privileges_mac()
        else:
            raise OSError("Unsupported operating system for privilege escalation")
    else:
        print("Escalated privileges to write to /etc/hosts.")
