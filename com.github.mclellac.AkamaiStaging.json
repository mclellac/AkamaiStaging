{
  "app-id": "com.github.mclellac.AkamaiStaging",
  "runtime": "org.gnome.Platform",
  "runtime-version": "46",
  "sdk": "org.gnome.Sdk",
  "command": "akamaistaging",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--device=dri",
    "--socket=wayland",
    "--env=FLATPAK_SANDBOX_DIR=/run/flatpak",
    "--filesystem=host",
    "--filesystem=/etc",
    "--talk-name=org.freedesktop.Flatpak",
    "--talk-name=org.freedesktop.portal.*"
  ],
  "cleanup": [
    "*.pyc",
    "*.pyo",
    "*.so",
    "__pycache__"
  ],
  "modules": [
    {
      "name": "akamaistaging",
      "buildsystem": "meson",
      "config-opts": [
        "--prefix=/app"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/mclellac/AkamaiStaging.git",
          "branch": "main"
        }
      ],
      "build-options": {
        "env": {
          "FLATPAK_BUILD": "1"
        },
        "build-args": [
          "--share=network"
        ]
      }
    },
    {
      "name": "dnspython",
      "buildsystem": "simple",
      "build-commands": [
        "pip3 install --prefix=/app git+https://github.com/rthalley/dnspython.git"
      ],
      "build-options": {
        "env": {
          "FLATPAK_BUILD": "1"
        },
        "build-args": [
          "--share=network"
        ]
      }
    },
    {
      "name": "polkit-policy",
      "buildsystem": "simple",
      "build-commands": [
        "install -Dm644 com.github.mclellac.AkamaiStaging.policy /etc/polkit-1/actions/com.github.mclellac.AkamaiStaging.policy"
      ],
      "sources": [
        {
          "type": "file",
          "path": "com.github.mclellac.AkamaiStaging.policy"
        }
      ]
    }
  ],
  "cleanup": [
    "*.pyc",
    "*.pyo",
    "*.so",
    "__pycache__"
  ]
}
